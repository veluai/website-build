      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "@id": "https://velu.us/services/nonprofit-outsourced-accounting-services#offer-catalog",
        "name": "Nonprofit Outsourced Accounting Services",
        "itemListElement": [
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Financial Reporting",
              "description": "Clear, timely nonprofit financial reporting, including monthly financial statements, budget-to-actual reporting, board-ready reporting packages, cash- and accrual-basis reporting, and custom reports."
            }
          },
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Fund Accounting",
              "description": "Fund accounting support for grants, programs, and restricted funds, including restricted fund tracking, grant reporting support, program-level reporting, revenue recognition, and fund balance monitoring."
            }
          },
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Financial Visibility",
              "description": "Financial analysis and reporting that helps nonprofit leaders understand trends, risks, and opportunities through variance analysis, benchmarking, cash flow analysis, general ledger management, and financial health monitoring."
            }
          },
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Accounting Operations",
              "description": "Dependable nonprofit accounting systems and processes, including timely bookkeeping, bank reconciliations, internal accountant oversight, chart of accounts maintenance, and month-end close procedures."
            }
          }
        ]
      },
